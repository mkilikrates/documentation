###############################################################################
# FULL TETRAGON SUPPORT - WSL2 6.18 KERNEL CONFIG FRAGMENT
#
# The WSL2 6.18 kernel (linux-msft-wsl-6.18.y) already has most features
# enabled. This fragment adds the MISSING options for FULL Tetragon support.
#
# Usage:
#   git clone --depth 1 -b linux-msft-wsl-6.18.y https://github.com/microsoft/WSL2-Linux-Kernel.git
#   cd WSL2-Linux-Kernel
#   cp arch/x86/configs/config-wsl .config
#   ./scripts/kconfig/merge_config.sh .config kind-tetragon.config
#   make olddefconfig
#   make -j$(nproc) bzImage
#
# Target: WSL2 kernel 6.18 (linux-msft-wsl-6.18.y)
# Purpose: Kind clusters with iptables/IPVS/nftables proxy + FULL Tetragon
###############################################################################

###############################################################################
# MISSING FROM DEFAULT WSL2 6.18 — REQUIRED FOR FULL TETRAGON
###############################################################################

# Fprobe: function-level probing framework used by newer Tetragon versions
# for multi-kprobe and fentry/fexit based hooks (more efficient than kprobes)
CONFIG_FPROBE=y

# BPF Stream Parser: enables sockmap/sockhash BPF programs
# Used by Tetragon for socket-level monitoring and enforcement
CONFIG_BPF_STREAM_PARSER=y

# BPF Kprobe Override: allows BPF programs to override kprobed function return
# CRITICAL for Tetragon enforcement (override_return action in TracingPolicy)
# This is what enables blocking syscalls/functions by returning errors
# Depends on CONFIG_FUNCTION_ERROR_INJECTION
CONFIG_FUNCTION_ERROR_INJECTION=y
CONFIG_BPF_KPROBE_OVERRIDE=y

###############################################################################
# ALREADY ENABLED (confirming for completeness / older kernels)
###############################################################################

# Core BPF (already =y in 6.18)
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_BPF_JIT_ALWAYS_ON=y
CONFIG_BPF_LSM=y
CONFIG_BPF_UNPRIV_DEFAULT_OFF=y

# BTF - required for CO-RE and kprobe argument parsing (already =y in 6.18)
CONFIG_DEBUG_INFO=y
CONFIG_DEBUG_INFO_DWARF_TOOLCHAIN_DEFAULT=y
CONFIG_DEBUG_INFO_BTF=y
CONFIG_DEBUG_INFO_BTF_MODULES=y
CONFIG_PAHOLE_HAS_SPLIT_BTF=y

# Kprobes - required for kprobe-based tracing policies (already =y in 6.18)
CONFIG_KPROBES=y
CONFIG_KPROBE_EVENTS=y
CONFIG_KRETPROBES=y
CONFIG_HAVE_KPROBES=y
CONFIG_HAVE_KRETPROBES=y

# Uprobes - required for uprobe-based tracing policies (already =y in 6.18)
CONFIG_UPROBES=y
CONFIG_UPROBE_EVENTS=y

# Tracing infrastructure (already =y in 6.18)
CONFIG_TRACEPOINTS=y
CONFIG_TRACING=y
CONFIG_FTRACE=y
CONFIG_FTRACE_SYSCALLS=y
CONFIG_FUNCTION_TRACER=y
CONFIG_DYNAMIC_FTRACE=y

# Perf + BPF events (already =y in 6.18)
CONFIG_PERF_EVENTS=y
CONFIG_BPF_EVENTS=y

# Security / LSM (already enabled in 6.18)
CONFIG_SECURITY=y
CONFIG_SECURITYFS=y
# NOTE: The default 6.18 LSM list is:
#   "landlock,lockdown,yama,loadpin,safesetid,integrity,selinux,apparmor,tomoyo"
# To enable BPF LSM enforcement (Tetragon override/sigkill via LSM hooks),
# append "bpf" to the LSM list:
CONFIG_LSM="landlock,lockdown,yama,loadpin,safesetid,integrity,selinux,apparmor,bpf"

# Cgroup BPF - container-aware filtering (already =y in 6.18)
CONFIG_CGROUP_BPF=y

# Audit (already =y in 6.18)
CONFIG_AUDIT=y
CONFIG_AUDITSYSCALL=y

# Seccomp (already =y in 6.18)
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y

###############################################################################
# KIND / DOCKER / K8S (all already enabled in 6.18, listed for reference)
###############################################################################

# Overlay FS (already =y in 6.18)
CONFIG_OVERLAY_FS=y

# Namespaces (already =y in 6.18)
CONFIG_NAMESPACES=y
CONFIG_USER_NS=y
CONFIG_NET_NS=y
CONFIG_PID_NS=y
CONFIG_IPC_NS=y
CONFIG_UTS_NS=y

# Cgroups (already =y in 6.18)
CONFIG_CGROUPS=y
CONFIG_MEMCG=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CPUSETS=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_SCHED=y

# Container networking (already enabled in 6.18)
CONFIG_VETH=y
CONFIG_BRIDGE=m
CONFIG_VXLAN=y
CONFIG_GENEVE=m
CONFIG_IPVLAN=m
CONFIG_MACVLAN=m
CONFIG_DUMMY=m
CONFIG_TUN=m
CONFIG_WIREGUARD=m
CONFIG_BRIDGE_NETFILTER=m

# IPVS (already =m in 6.18)
CONFIG_IP_VS=m
CONFIG_IP_VS_PROTO_TCP=y
CONFIG_IP_VS_PROTO_UDP=y
CONFIG_IP_VS_PROTO_SCTP=y
CONFIG_IP_VS_RR=m
CONFIG_IP_VS_WRR=m
CONFIG_IP_VS_SH=m
CONFIG_IP_VS_MH=m
CONFIG_IP_VS_LC=m
CONFIG_IP_VS_DH=m
CONFIG_IP_VS_LBLC=m
CONFIG_IP_VS_LBLCR=m
CONFIG_IP_VS_SED=m
CONFIG_IP_VS_NQ=m
CONFIG_IP_VS_NFCT=y
CONFIG_IP_VS_FTP=m

# nftables (already =y in 6.18)
CONFIG_NF_TABLES=y
CONFIG_NF_TABLES_INET=y
CONFIG_NF_TABLES_NETDEV=y
CONFIG_NFT_CT=m
CONFIG_NFT_COUNTER=m
CONFIG_NFT_LOG=m
CONFIG_NFT_LIMIT=m
CONFIG_NFT_MASQ=y
CONFIG_NFT_REDIR=m
CONFIG_NFT_NAT=y
CONFIG_NFT_REJECT=m
CONFIG_NFT_COMPAT=m
CONFIG_NFT_HASH=m
CONFIG_NFT_FIB=m
CONFIG_NFT_FIB_INET=m
CONFIG_NFT_FIB_IPV4=m
CONFIG_NFT_FIB_IPV6=m
CONFIG_NF_TABLES_IPV4=y
CONFIG_NF_TABLES_IPV6=y

# iptables (already =m in 6.18)
CONFIG_NETFILTER=y
CONFIG_NF_CONNTRACK=y
CONFIG_NETFILTER_XTABLES=y
CONFIG_IP_NF_IPTABLES=m
CONFIG_IP_NF_FILTER=m
CONFIG_IP_NF_NAT=m
CONFIG_IP_NF_MANGLE=m
CONFIG_IP_NF_RAW=m
CONFIG_IP6_NF_IPTABLES=m
CONFIG_IP6_NF_FILTER=m
CONFIG_IP6_NF_MANGLE=m
CONFIG_IP6_NF_RAW=m
CONFIG_IP6_NF_NAT=m

# TC/BPF networking (already enabled in 6.18)
CONFIG_NET_SCH_HTB=m
CONFIG_NET_SCH_INGRESS=m
CONFIG_NET_CLS_BPF=m
CONFIG_NET_CLS_ACT=y
CONFIG_NET_ACT_BPF=m
CONFIG_NET_ACT_MIRRED=m

# Modules (already =y in 6.18)
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
