###############################################################################
# FULL TETRAGON + KIND + ALL PROXY MODES - WSL2 6.18 KERNEL CONFIG FRAGMENT
#
# ALL options set to =y (built-in) to avoid module loading issues in WSL2.
# WSL2 doesn't auto-run depmod or auto-load modules, so building everything
# into the kernel image eliminates the need for modprobe/depmod entirely.
#
# COMPLETE BUILD FLOW (copy-paste for article):
#
#   git clone --depth 1 -b linux-msft-wsl-6.18.y https://github.com/microsoft/WSL2-Linux-Kernel.git
#   cd WSL2-Linux-Kernel
#   cp arch/x86/configs/config-wsl .config
#
#   # Merge this fragment
#   ./scripts/kconfig/merge_config.sh .config kind-tetragon.config
#
#   # Force ALL netfilter + IPVS + networking modules to built-in (=m → =y)
#   sed -i -E 's/^(CONFIG_(IP_NF|IP6_NF|NF_|NETFILTER_XT|NFT_|IP_VS).*)=m$/\1=y/' .config
#   sed -i -E 's/^(CONFIG_(BRIDGE|MACVLAN|IPVLAN|GENEVE|DUMMY|TUN|WIREGUARD|VLAN_8021Q).*)=m$/\1=y/' .config
#
#   # Force enforcement options that merge_config fails to override
#   sed -i 's/# CONFIG_FUNCTION_ERROR_INJECTION is not set/CONFIG_FUNCTION_ERROR_INJECTION=y/' .config
#   sed -i 's/# CONFIG_BPF_KPROBE_OVERRIDE is not set/CONFIG_BPF_KPROBE_OVERRIDE=y/' .config
#
#   # Resolve dependencies
#   make olddefconfig
#
#   # Build (no modules_install needed — everything critical is built-in)
#   make -j$(nproc) bzImage
#
#   # Deploy
#   cp arch/x86/boot/bzImage /mnt/c/Users/<YourUser>/wsl-kernel/bzImage
#
# Target: WSL2 kernel 6.18 (linux-msft-wsl-6.18.y)
# Purpose: Kind clusters with iptables/IPVS/nftables proxy + FULL Tetragon
###############################################################################

###############################################################################
# TETRAGON: eBPF + KPROBES + BTF + ENFORCEMENT
###############################################################################

# Core BPF
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_BPF_JIT_ALWAYS_ON=y
CONFIG_BPF_STREAM_PARSER=y
CONFIG_BPF_LSM=y
CONFIG_BPF_UNPRIV_DEFAULT_OFF=y
CONFIG_BPF_EVENTS=y

# BTF (required for Tetragon CO-RE)
CONFIG_DEBUG_INFO=y
CONFIG_DEBUG_INFO_DWARF_TOOLCHAIN_DEFAULT=y
CONFIG_DEBUG_INFO_BTF=y
CONFIG_DEBUG_INFO_BTF_MODULES=y
CONFIG_PAHOLE_HAS_SPLIT_BTF=y

# Kprobes
CONFIG_KPROBES=y
CONFIG_KPROBE_EVENTS=y
CONFIG_KRETPROBES=y
CONFIG_HAVE_KPROBES=y
CONFIG_HAVE_KRETPROBES=y

# Enforcement (override_return in TracingPolicy)
CONFIG_FUNCTION_ERROR_INJECTION=y
CONFIG_BPF_KPROBE_OVERRIDE=y

# Uprobes
CONFIG_UPROBES=y
CONFIG_UPROBE_EVENTS=y

# Fprobe (multi-kprobe / fentry/fexit)
CONFIG_FPROBE=y

# Tracing infrastructure
CONFIG_TRACEPOINTS=y
CONFIG_TRACING=y
CONFIG_FTRACE=y
CONFIG_FTRACE_SYSCALLS=y
CONFIG_FUNCTION_TRACER=y
CONFIG_FUNCTION_GRAPH_TRACER=y
CONFIG_DYNAMIC_FTRACE=y
CONFIG_DYNAMIC_FTRACE_WITH_REGS=y
CONFIG_DYNAMIC_EVENTS=y

# Perf events
CONFIG_PERF_EVENTS=y

# Symbols (for stack traces / function resolution)
CONFIG_KALLSYMS=y
CONFIG_KALLSYMS_ALL=y
CONFIG_STACKTRACE=y

# Kernel config access (/proc/config.gz)
CONFIG_IKCONFIG=y
CONFIG_IKCONFIG_PROC=y

# Audit
CONFIG_AUDIT=y
CONFIG_AUDITSYSCALL=y

# Debug filesystem (for kprobes/enabled)
CONFIG_DEBUG_FS=y

# Security / LSM — add "bpf" for Tetragon LSM enforcement
CONFIG_SECURITY=y
CONFIG_SECURITYFS=y
CONFIG_LSM="landlock,lockdown,yama,loadpin,safesetid,integrity,selinux,apparmor,bpf"

# Cgroup BPF
CONFIG_CGROUP_BPF=y

# Seccomp
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y

###############################################################################
# CONTAINER / DOCKER / KIND BASICS (all =y for WSL2 reliability)
###############################################################################

# Namespaces
CONFIG_NAMESPACES=y
CONFIG_USER_NS=y
CONFIG_NET_NS=y
CONFIG_PID_NS=y
CONFIG_IPC_NS=y
CONFIG_UTS_NS=y

# Cgroups v2
CONFIG_CGROUPS=y
CONFIG_MEMCG=y
CONFIG_BLK_CGROUP=y
CONFIG_CGROUP_SCHED=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CPUSETS=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_PERF=y
CONFIG_PROC_PID_CPUSET=y

# Overlay filesystem
CONFIG_OVERLAY_FS=y

# Loop device (KinD node images)
CONFIG_BLK_DEV_LOOP=y

# Keys (container image verification)
CONFIG_KEYS=y

###############################################################################
# NETWORKING — ALL BUILT-IN (=y) FOR WSL2
###############################################################################

# Virtual devices
CONFIG_VETH=y
CONFIG_BRIDGE=y
CONFIG_BRIDGE_NETFILTER=y
CONFIG_VXLAN=y
CONFIG_GENEVE=y
CONFIG_IPVLAN=y
CONFIG_MACVLAN=y
CONFIG_DUMMY=y
CONFIG_TUN=y
CONFIG_WIREGUARD=y
CONFIG_VLAN_8021Q=y

# Core netfilter
CONFIG_NETFILTER=y
CONFIG_NETFILTER_ADVANCED=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_CONNTRACK_MARK=y
CONFIG_NF_CONNTRACK_EVENTS=y
CONFIG_NF_CONNTRACK_LABELS=y
CONFIG_NF_NAT=y
CONFIG_NF_NAT_MASQUERADE=y
CONFIG_NETFILTER_NETLINK=y
CONFIG_NETFILTER_NETLINK_QUEUE=y
CONFIG_NETFILTER_NETLINK_LOG=y
CONFIG_NETFILTER_XTABLES=y

# Xtables matches (Docker requires these — the source of the failure)
CONFIG_NETFILTER_XT_MATCH_ADDRTYPE=y
CONFIG_NETFILTER_XT_MATCH_BPF=y
CONFIG_NETFILTER_XT_MATCH_COMMENT=y
CONFIG_NETFILTER_XT_MATCH_CONNMARK=y
CONFIG_NETFILTER_XT_MATCH_CONNTRACK=y
CONFIG_NETFILTER_XT_MATCH_IPVS=y
CONFIG_NETFILTER_XT_MATCH_MULTIPORT=y
CONFIG_NETFILTER_XT_MATCH_STATISTIC=y
CONFIG_NETFILTER_XT_MATCH_RECENT=y
CONFIG_NETFILTER_XT_MATCH_MARK=y
CONFIG_NETFILTER_XT_MATCH_LIMIT=y
CONFIG_NETFILTER_XT_MATCH_STATE=y

# Xtables targets
CONFIG_NETFILTER_XT_TARGET_MARK=y
CONFIG_NETFILTER_XT_TARGET_MASQUERADE=y
CONFIG_NETFILTER_XT_TARGET_REDIRECT=y
CONFIG_NETFILTER_XT_TARGET_TPROXY=y
CONFIG_NETFILTER_XT_NAT=y
CONFIG_NETFILTER_XT_MARK=y
CONFIG_NETFILTER_XT_CONNMARK=y

###############################################################################
# IPTABLES MODE (all =y)
###############################################################################

# IPv4 REJECT target core
CONFIG_NF_REJECT_IPV4=y

CONFIG_IP_NF_IPTABLES=y
CONFIG_IP_NF_FILTER=y
CONFIG_IP_NF_NAT=y
CONFIG_IP_NF_TARGET_MASQUERADE=y
CONFIG_IP_NF_TARGET_REDIRECT=y
CONFIG_IP_NF_TARGET_REJECT=y
CONFIG_IP_NF_MANGLE=y
CONFIG_IP_NF_RAW=y

# IPv6 REJECT target core
CONFIG_NF_REJECT_IPV6=y

CONFIG_IP6_NF_IPTABLES=y
CONFIG_IP6_NF_FILTER=y
CONFIG_IP6_NF_MANGLE=y
CONFIG_IP6_NF_RAW=y
CONFIG_IP6_NF_NAT=y
CONFIG_IP6_NF_TARGET_REJECT=y
CONFIG_IP6_NF_TARGET_MASQUERADE=y

###############################################################################
# NFTABLES MODE (all =y)
###############################################################################

CONFIG_NF_TABLES=y
CONFIG_NF_TABLES_INET=y
CONFIG_NF_TABLES_IPV4=y
CONFIG_NF_TABLES_IPV6=y
CONFIG_NF_TABLES_NETDEV=y
CONFIG_NF_TABLES_BRIDGE=y
CONFIG_NFT_CT=y
CONFIG_NFT_COUNTER=y
CONFIG_NFT_NUMGEN=y
CONFIG_NFT_CONNLIMIT=y
CONFIG_NFT_LOG=y
CONFIG_NFT_LIMIT=y
CONFIG_NFT_MASQ=y
CONFIG_NFT_REDIR=y
CONFIG_NFT_NAT=y
CONFIG_NFT_REJECT=y
CONFIG_NFT_COMPAT=y
CONFIG_NFT_HASH=y
CONFIG_NFT_FIB=y
CONFIG_NFT_FIB_INET=y
CONFIG_NFT_FIB_IPV4=y
CONFIG_NFT_FIB_IPV6=y
CONFIG_NFT_QUEUE=y
CONFIG_NFT_QUOTA=y
CONFIG_NFT_TUNNEL=y

###############################################################################
# IPVS MODE (all =y)
###############################################################################

CONFIG_IP_VS=y
CONFIG_IP_VS_IPV6=y
CONFIG_IP_VS_PROTO_TCP=y
CONFIG_IP_VS_PROTO_UDP=y
CONFIG_IP_VS_PROTO_SCTP=y
CONFIG_IP_VS_PROTO_ESP=y
CONFIG_IP_VS_PROTO_AH=y
CONFIG_IP_VS_RR=y
CONFIG_IP_VS_WRR=y
CONFIG_IP_VS_LC=y
CONFIG_IP_VS_WLC=y
CONFIG_IP_VS_FO=y
CONFIG_IP_VS_OVF=y
CONFIG_IP_VS_LBLC=y
CONFIG_IP_VS_LBLCR=y
CONFIG_IP_VS_DH=y
CONFIG_IP_VS_SH=y
CONFIG_IP_VS_MH=y
CONFIG_IP_VS_SED=y
CONFIG_IP_VS_NQ=y
CONFIG_IP_VS_NFCT=y
CONFIG_IP_VS_FTP=y

###############################################################################
# ROUTING (required for multi-path, policy routing in K8s CNI)
###############################################################################

CONFIG_IP_ADVANCED_ROUTER=y
CONFIG_IP_MULTIPLE_TABLES=y
CONFIG_IP_ROUTE_MULTIPATH=y
CONFIG_IPV6_MULTIPLE_TABLES=y
CONFIG_IPV6_SUBTREES=y
CONFIG_IP_MULTICAST=y

###############################################################################
# BPF NETWORKING (TC/XDP integration)
###############################################################################

CONFIG_NET_CLS_BPF=y
CONFIG_NET_CLS_ACT=y
CONFIG_NET_ACT_BPF=y
CONFIG_NET_ACT_MIRRED=y
CONFIG_NET_SCH_HTB=y
CONFIG_NET_SCH_INGRESS=y

###############################################################################
# FILESYSTEM
###############################################################################

CONFIG_EXT4_FS=y
CONFIG_XFS_FS=y
CONFIG_FUSE_FS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_XATTR=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_INOTIFY_USER=y
CONFIG_FANOTIFY=y
CONFIG_FANOTIFY_ACCESS_PERMISSIONS=y
CONFIG_ISO9660_FS=y

###############################################################################
# XFRM / IPSEC (for encrypted pod-to-pod traffic)
###############################################################################

CONFIG_XFRM=y
CONFIG_XFRM_USER=y
CONFIG_XFRM_ALGO=y
CONFIG_INET_ESP=y

###############################################################################
# DISABLE UNNECESSARY HARDWARE MODULES (cause BTF CO-RE issues in Tetragon)
# WSL2 has no physical hardware — these ACPI modules have malformed BTF
# that causes: "apply CO-RE relocations: load BTF for kmod ac: ..."
###############################################################################

# CONFIG_ACPI_AC is not set
# CONFIG_ACPI_BATTERY is not set
# CONFIG_ACPI_FAN is not set
# CONFIG_ACPI_VIDEO is not set
# CONFIG_ACPI_BUTTON is not set

###############################################################################
# FORCE ALL NETFILTER/IPTABLES/IPVS FROM =m TO =y
# This is handled by sed AFTER merge_config.sh:
#   sed -i -E 's/^(CONFIG_(IP_NF|IP6_NF|NF_|NETFILTER_XT|NFT_|IP_VS).*)=m$/\1=y/' .config
#
# Additionally force BRIDGE and other network devices:
#   sed -i -E 's/^(CONFIG_(BRIDGE|MACVLAN|IPVLAN|GENEVE|DUMMY|TUN|WIREGUARD|VLAN_8021Q).*)=m$/\1=y/' .config
#
# And force enforcement options:
#   sed -i 's/# CONFIG_FUNCTION_ERROR_INJECTION is not set/CONFIG_FUNCTION_ERROR_INJECTION=y/' .config
#   sed -i 's/# CONFIG_BPF_KPROBE_OVERRIDE is not set/CONFIG_BPF_KPROBE_OVERRIDE=y/' .config
###############################################################################

###############################################################################
# MODULES (still allow loading, but everything critical is built-in)
###############################################################################

CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
