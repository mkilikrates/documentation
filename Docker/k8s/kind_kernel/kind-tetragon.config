###############################################################################
# TETRAGON + KIND + ALL PROXY MODES - WSL2 6.18 KERNEL CONFIG FRAGMENT
#
# This fragment contains ONLY the options that differ from the default
# WSL2 config (arch/x86/configs/config-wsl). All options are set to =y
# (built-in) to avoid module loading issues in WSL2.
#
# WSL2 doesn't auto-run depmod or auto-load modules, so building everything
# into the kernel image eliminates the need for modprobe/depmod entirely.
#
# COMPLETE BUILD FLOW:
#
#   git clone --depth 1 -b linux-msft-wsl-6.18.y https://github.com/microsoft/WSL2-Linux-Kernel.git
#   cd WSL2-Linux-Kernel
#   cp arch/x86/configs/config-wsl .config
#
#   # Merge this fragment (all changes are self-contained here)
#   ./scripts/kconfig/merge_config.sh .config kind-tetragon.config
#
#   # Resolve dependencies
#   make olddefconfig
#
#   # Re-apply ACPI disables (olddefconfig may re-enable them)
#   ./scripts/kconfig/merge_config.sh .config kind-tetragon.config
#
#   # Build (no modules_install needed — everything critical is built-in)
#   make -j$(nproc) bzImage
#
#   # Deploy
#   cp arch/x86/boot/bzImage /mnt/c/Users/<YourUser>/wsl-kernel/bzImage
#
#   # mount bpf and securityfs (WSL2 doesn't mount these by default)
#   echo "bpffs /sys/fs/bpf bpf defaults 0 0" | sudo tee -a /etc/fstab
#   echo "securityfs /sys/kernel/security securityfs defaults 0 0" | sudo tee -a /etc/fstab
#
# Target: WSL2 kernel 6.18 (linux-msft-wsl-6.18.y)
# Purpose: Kind clusters with iptables/IPVS/nftables proxy + FULL Tetragon
###############################################################################

###############################################################################
# TETRAGON: BTF + ENFORCEMENT
# (kprobes, uprobes, tracing, perf, kallsyms, etc. already enabled in WSL)
###############################################################################

# BTF — disable module BTF (not needed, avoids CO-RE issues)
# CONFIG_DEBUG_INFO_BTF_MODULES is not set

# Enforcement (override_return in TracingPolicy)
CONFIG_FUNCTION_ERROR_INJECTION=y
CONFIG_BPF_KPROBE_OVERRIDE=y

# Fprobe (multi-kprobe / fentry/fexit)
CONFIG_FPROBE=y

# Security / LSM — add "bpf" to the list for Tetragon LSM enforcement
CONFIG_SECURITY_TOMOYO=y
CONFIG_LSM="landlock,lockdown,yama,loadpin,safesetid,integrity,selinux,apparmor,tomoyo,bpf"

###############################################################################
# DISABLE UNNECESSARY HARDWARE MODULES (cause BTF CO-RE issues in Tetragon)
# WSL2 has no physical hardware — these ACPI modules have malformed BTF
# that causes: "apply CO-RE relocations: load BTF for kmod ac: ..."
# Fixed upstream but not yet in stable Tetragon, so disable for now.
###############################################################################

# CONFIG_ACPI_AC is not set
# CONFIG_ACPI_BATTERY is not set
# CONFIG_ACPI_BUTTON is not set
# CONFIG_ACPI_FAN is not set
# CONFIG_ACPI_IPMI is not set
# CONFIG_ACPI_PLATFORM_PROFILE is not set
# CONFIG_ACPI_THERMAL is not set
# CONFIG_ACPI_VIDEO is not set
# CONFIG_ACPI_WMI is not set
# CONFIG_ACPI_APEI_ERST_DEBUG is not set

###############################################################################
# NETWORKING — VIRTUAL DEVICES (=m -> =y)
###############################################################################

CONFIG_BRIDGE=y
CONFIG_BRIDGE_NETFILTER=y
CONFIG_DUMMY=y
CONFIG_GENEVE=y
CONFIG_IPVLAN=y
CONFIG_MACVLAN=y
CONFIG_TUN=y
CONFIG_VLAN_8021Q=y
CONFIG_WIREGUARD=y

###############################################################################
# NETWORK PROTOCOL SUPPORT (=m -> =y, dependencies for bridge/VLAN)
###############################################################################

CONFIG_LLC=y
CONFIG_STP=y
CONFIG_GARP=y
CONFIG_MRP=y

###############################################################################
# BRIDGE EBTABLES (=m -> =y)
